{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "target": "ESNext",
    "module": "ESNext",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "Bundler",
    "isolatedModules": true,
    // Add any Jest-specific compiler options here
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts", "jest.config.ts", "src/**/*.test.ts", "src/**/*.test.tsx"]
}
